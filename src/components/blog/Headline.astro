---
const { title = await Astro.slots.render('default'), subtitle = await Astro.slots.render('subtitle') } = Astro.props;
---

<header class="mb-6 md:mb-8 text-center max-w-3xl mx-auto">
  <h1 class="text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading" set:html={title} />
  {
    subtitle && (
      <div class="mt-1 md:mt-2 mx-auto text-lg text-gray-500 dark:text-slate-400 font-medium" set:html={subtitle} />
    )
  }
</header>
