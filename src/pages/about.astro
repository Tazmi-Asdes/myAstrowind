---
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '关于我',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="About" title="关于我">
    <Fragment slot="subtitle"> 大学应届生 · 热爱运维与后端开发 · 乐于实践与开源 </Fragment>
  </HeroText>

  <!-- 工作领域 Widget ************** -->

  <Features
    tagline="技术方向"
    title="在校期间学习与实践的技术领域"
    columns={3}
    items={[
      {
        title: '服务器运维',
        description:
          '熟悉 Linux 系统管理与常见中间件部署，掌握 Docker、Kubernetes 容器化技术基础，通过个人项目搭建过完整的服务器环境，包括 DDNS、Nginx 反向代理与防火墙配置。',
        icon: 'tabler:server',
      },
      {
        title: '后端开发',
        description:
          '学习并实践 Java 生态技术栈，包括 Spring Boot、Spring Cloud、MyBatis 框架。在校期间完成过多个课程项目，了解 RESTful API 设计、数据库建模与微服务基础架构。',
        icon: 'tabler:code',
      },
      {
        title: 'DevOps 与自动化',
        description:
          '了解 CI/CD 流水线理念，使用过 GitHub Actions 与 Jenkins 进行自动化构建部署。通过自己搭建博客和项目站点的实践，熟悉了从代码提交到服务上线的完整流程。',
        icon: 'tabler:infinity',
      },
    ]}
  />
</Layout>
