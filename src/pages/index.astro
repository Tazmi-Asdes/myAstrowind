---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'MyBlog — 个人技术博客',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero2
    isReversed
    image={{ src: '~/assets/images/tazmi.jpg', alt: 'Tazmi 头像', class: 'mx-auto rounded-full w-48 h-48 lg:w-64 lg:h-64 object-cover' }}
  >
    <Fragment slot="title">
      林子航 <span class="text-accent dark:text-white">Tazmi</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">技术爱好者</span> · 服务器运维 · 后端开发 · 开源
    </Fragment>
  </Hero2>

  <!-- 技术栈 Widget *************** -->

  <Features
    id="skills"
    tagline="技能"
    title="技术栈与工具"
    items={[
      {
        title: '服务器运维',
        description: '熟悉 Linux 系统管理与维护，掌握 Docker、Kubernetes 容器化技术，具备生产环境运维经验。',
        icon: 'tabler:server',
      },
      {
        title: '后端开发',
        description: '使用 Java、Spring Boot 进行后端服务开发，熟悉 RESTful API 设计、微服务架构与数据库管理。',
        icon: 'tabler:code',
      },
      {
        title: '自动化与 CI/CD',
        description: '掌握 GitHub Actions、Jenkins 等 CI/CD 工具，善于构建自动化部署流水线。',
        icon: 'tabler:refresh',
      },
      {
        title: '开源贡献',
        description: '积极参与开源社区，关注云原生技术生态，乐于分享技术实践与经验。',
        icon: 'tabler:heart',
      },
    ]}
  />

  <!-- 博客 Widget ******************* -->

  <BlogLatestPosts title="最新文章" information="记录项目实践中的技术探索与心得。" />

  <!-- 联系方式 Widget ************** -->

  <Features2
    title="与我联系"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'GitHub',
        description: 'github.com/Tazmi-Asdes',
        icon: 'tabler:brand-github',
      },
      {
        title: '邮箱',
        description: '2926238971@qq.com',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
